# =========================================================================
# Bước 1: Chọn môi trường nền (Base Image) là PHP 8.2 kết hợp FPM (FastCGI)
# =========================================================================
FROM php:8.2-fpm

# Thiết lập thư mục làm việc bên trong container
WORKDIR /var/www

# =========================================================================
# Bước 2: Cài đặt các công cụ hệ thống và các PHP Extensions mà Laravel cần
# =========================================================================
RUN apt-get update && apt-get install -y \
    git \
    curl \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    zip \
    unzip \
    nano \
    nodejs \
    npm	

# Xóa bộ nhớ cache của apt để container nhẹ hơn
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# Cài đặt các extension cốt lõi của PHP cho Laravel (MySQL, BCMath, GD, Mbstring...)
RUN docker-php-ext-install pdo_mysql mbstring exif pcntl bcmath gd

# =========================================================================
# Bước 3: Cài đặt Composer (Trình quản lý thư viện của PHP)
# =========================================================================
# Cách này siêu nhanh: Copy trực tiếp file thực thi Composer từ Image chính thức sang
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# =========================================================================
# Bước 4: Copy toàn bộ Source Code của anh vào trong Container
# =========================================================================
COPY . /var/www

# =========================================================================
# Bước 5: Phân quyền - BƯỚC NÀY CỰC KỲ QUAN TRỌNG VỚI LARAVEL!
# =========================================================================
# Mặc định Laravel chạy dưới quyền của user 'www-data' trong Linux
RUN chown -R www-data:www-data /var/www

# Cấp quyền ghi cho thư mục storage và bootstrap/cache để không bị lỗi 500
RUN chmod -R 775 /var/www/storage /var/www/bootstrap/cache

# Mở cổng 9000 (Cổng mặc định của PHP-FPM)
EXPOSE 9000

# Lệnh mặc định để khởi chạy PHP-FPM khi container chạy
CMD ["php-fpm"]
